{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Debug Backend (TS Clean)",
      "type": "node",
      "request": "launch",

      "runtimeArgs": [
        "-r",
        "@swc-node/register"
      ],

      "program": "${workspaceFolder}/server/src/presentation/express/setting/index.ts",

      "cwd": "${workspaceFolder}/server",

      "console": "integratedTerminal",

      "sourceMaps": true,

      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/server/node_modules/**",
        "**/node_modules/**"
      ]
    },

    {
      "name": "Debug Frontend (React + Vite)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client",
      "sourceMaps": true,
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ]
    }

  ]
}